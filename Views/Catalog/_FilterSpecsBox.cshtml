        { "Rojo", "#DF1313" },
        { "Naranja", "#F06A27" },
        { "Amarillo", "#F7EB11" },
        { "Verde", "#3EB210" },
        { "Cyan", "#2CBADE" },
        { "Azul", "#2E21A9" },
        { "Morado", "#7C21A9" },
        { "Rosa", "#EE2EB8" },
        { "Vino", "#951B31" },
        { "Marron", "#976147" },
        { "Natural", "#EFCEAC" },
        { "Negro", "#1F1F1E" },
        { "Gris", "#BEBEBE" },
        { "Blanco", "#F2F7F0" },
    };

    var valueToColorBase = new Dictionary<int, string>();
