        if (rgb.startsWith("#")) return rgb.toUpperCase();
        const result = rgb.match(/\d+/g);
        if (!result || result.length < 3) return "";
        return "#" + result.slice(0, 3).map(x => ("0" + parseInt(x).toString(16)).slice(-2).toUpperCase()).join("");
    }

    function aplicarColorAProductos(coloresSeleccionados) {
        if (coloresSeleccionados.length === 0) return;
        let hexesBuscados = [];
        coloresSeleccionados.forEach(colorBase => {
            if (colorGroups[colorBase]) hexesBuscados = hexesBuscados.concat(colorGroups[colorBase]);
        });
        if (hexesBuscados.length === 0) return;
        setTimeout(() => {
            document.querySelectorAll(".product-item").forEach(producto => {
                const topos = producto.querySelectorAll(".variant-preview");
                for (let topo of topos) {
                    const bg = window.getComputedStyle(topo).backgroundColor;
                    if (!bg) continue;
                    const hex = rgbToHex(bg);
                    if (hexesBuscados.includes(hex)) { topo.click(); break; }
                }
            });
        }, 300);
    }

    $visibleAttributes.on('change', function () {
        var optionId = $(this).data('option-id');
        $realOptions.filter('[data-option-id="' + optionId + '"]').prop('checked', $(this).is(':checked'));
        CatalogProducts.getProducts();
    });

    $baseColorCheckboxes.on('change', function () {
        var colorBase = $(this).data('color-base');
        $realOptions.filter('[data-color-base="' + colorBase + '"]').prop('checked', $(this).is(':checked'));
        CatalogProducts.getProducts();
        var coloresSeleccionados = [];
        $baseColorCheckboxes.filter(':checked').each(function() { coloresSeleccionados.push($(this).data('color-base')); });
        aplicarColorAProductos(coloresSeleccionados);
    });

    $materialCheckboxes.on('change', function () {
        var family = $(this).data('material-family');
        var isChecked = $(this).is(':checked');
        $realOptions.filter('[data-material-family="' + family + '"]').prop('checked', isChecked);
        CatalogProducts.getProducts();
    });

    $capacityCheckboxes.on('change', function () {
        var range = $(this).data('capacity-range');
        $realOptions.filter('[data-capacity-range="' + range + '"]').prop('checked', $(this).is(':checked'));
        CatalogProducts.getProducts();
    });

    var $gramajeCheckboxes = $('.gramaje-range-checkbox');
    $gramajeCheckboxes.on('change', function () {
        var g = $(this).data('gramaje-range');
        $realOptions.filter('[data-gramaje-range="' + g + '"]').prop('checked', $(this).is(':checked'));
        CatalogProducts.getProducts();
    });

    $realOptions.on('change', function () { CatalogProducts.getProducts(); });

    $(CatalogProducts).on('loaded', function() {
        var coloresSeleccionados = [];
        $baseColorCheckboxes.filter(':checked').each(function() { coloresSeleccionados.push($(this).data('color-base')); });
        if (coloresSeleccionados.length > 0) aplicarColorAProductos(coloresSeleccionados);
    });

    $(CatalogProducts).on('before', function (e) {
        var selectedOptions = [];
        $realOptions.each(function() {
            if ($(this).is(':checked')) selectedOptions.push($(this).data('option-id'));
        });
        if (selectedOptions.length > 0) e.payload.urlBuilder.addParameter('specs', selectedOptions.join(','));
    });
});
</script>

<style>
    .color-circle {
        display: inline-block;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid #ddd;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .color-circle:hover {
        transform: scale(1.1);
        border-color: #999;
    }
    .base-color-checkbox:checked + .color-circle {
        box-shadow: 0 0 0 1px #fff, 0 0 0 2px #999;
    }
</style>
