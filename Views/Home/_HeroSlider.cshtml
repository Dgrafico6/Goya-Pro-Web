<section class="tns-carousel tns-controls-md banner-home">
    <!-- Hero slider-->
    <div class="tns-carousel-inner banner-home__inner" 
        data-carousel-options="{&quot;mode&quot;: &quot;gallery&quot;, &quot;responsive&quot;: {&quot;0&quot;:{&quot;nav&quot;:true, &quot;controls&quot;: false},&quot;992&quot;:{&quot;nav&quot;:false, &quot;controls&quot;: true}}}">

        <div class="banner-home__item" style="background-color:@T("goya.theme.home.banner-0-1.bgcolor.catal2026");">
            <div class="banner-home__container container">
                <div class="banner-home__content">
                    <div class="banner-home__gallery">
                        <img class="banner-home__image" src="@T("goya.theme.home.banner-0-1.image.catal2026")" alt="@T("goya.theme.home.banner-0-1.title.catal2026")">
                    </div>
                    <div class="banner-home__data">
                        <h2 class="display-3 banner-home__title from-top delay-1">@T("goya.theme.home.banner-0-1.title.catal2026")</h2>
						<!-- <p class="banner-home__text mb-3 from-top delay-2">@T("goya.theme.home.banner-0-1.title.text.catal2026")</p>-->
                        <p class="banner-home__text mb-3 from-top delay-2">@T("goya.theme.home.banner-0-1.title.p1")</p>
                        <div class="banner-home__actions scale-up delay-4"><a class="btn btn-light" href="@T("goya.theme.home.banner-1.link.href.catal2026")" target="_blank">@T("goya.theme.home.banner-0-1.link.text.catal2026")</a></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="banner-home__item" style="background-color: purple;">
            <div class="banner-home__container container">
                <div class="banner-home__content">
                    <div class="banner-home__gallery">
                        <img class="banner-home__image" src="@T("goya.theme.home.banner-0-1.image.catal2026")" alt="@T("goya.theme.home.banner-0-1.title.catal2026")">
                    </div>
                    <div class="banner-home__data">
                        <h2 class="display-3 banner-home__title from-top delay-1">@T("goya.theme.home.banner-0-1.title.catal2026")</h2>
						<!-- <p class="banner-home__text mb-3 from-top delay-2">@T("goya.theme.home.banner-0-1.title.text.catal2026")</p>-->
                        <p class="banner-home__text mb-3 from-top delay-2">@T("goya.theme.home.banner-0-1.title.p1")</p>
                        <div class="banner-home__actions scale-up delay-4"><a class="btn btn-light" href="@T("goya.theme.home.banner-1.link.href.catal2026")" target="_blank">@T("goya.theme.home.banner-0-1.link.text.catal2026")</a></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>







