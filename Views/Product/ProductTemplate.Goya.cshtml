<!-- Script MAPEO ICONOS -->
<script src="~/js/icon-text-map.js"></script>

<!-- Script Iconos -->
<script src="~/js/open-icons.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Ocultar filas con guión
        document.querySelectorAll('#specifications table tr').forEach(function (row) {
            row.querySelectorAll('td').forEach(function (cell) {
                if (cell.textContent.trim() === '-') {
                    row.style.display = 'none';
                }
            });
        });

        // Eliminar filas duplicadas (basado en el contenido completo de la fila)
        const seen = new Set();
        document.querySelectorAll('#specifications table tr').forEach(function (row) {
            const cells = row.querySelectorAll('td');
            if (cells.length > 0) {
                const rowContent = Array.from(cells)
                    .map(cell => cell.textContent.trim().toLowerCase())
                    .join('|');
                if (seen.has(rowContent)) {
                    row.style.display = 'none';
                } else {
                    seen.add(rowContent);
                }
            }
        });
    });

/* Oculta el mensaje de plazos por Año Chino Comentar este SCRIPT PARA QUE SE VUELVA A VER */
    (function () {
        const textsToHide = [
            "Los plazos son sin tener en cuenta el cierre de fábricas por el Nuevo Año Chino.",
            "Lead times are indicated without taking into account factory closures for the Chinese New Year.",
            "Els terminis s'indiquen sense tenir en compte el tancament de fàbriques pel Nou Any Xinès.",
            "Os prazos são indicados sem ter em conta o encerramento das fábricas para o Ano Novo Chinês.",
            "Les délais sont indiqués sans tenir compte de la fermeture des usines pour le Nouvel An chinois."
        ];

        function hideTexts() {
            document.querySelectorAll("b").forEach(el => {
                const text = el.textContent.trim();
                textsToHide.forEach(t => {
                    if (text === t) {
                        el.style.display = "none";
                    }
                });
            });
        }

        // Ejecutar lo antes posible
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", hideTexts);
        } else {
            hideTexts();
        }

        // MutationObserver por si el contenido carga dinámicamente
        const observer = new MutationObserver(hideTexts);
        observer.observe(document.documentElement, { childList: true, subtree: true });
    })();

    @* Oculta el mensaje de plazos por Año Chino *@

</script>