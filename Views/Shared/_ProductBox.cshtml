<script src="~/js/arrows.js"></script>
<script>
function formatStock(container) {
    const allText = container.innerText;

    const stockMatch = allText.match(/Stock:\s*([\d,\.]+)/i);
    if (!stockMatch) return;

    let rawNumber = stockMatch[1].replace(/[.,]/g, '');
    let stockNumber = parseInt(rawNumber, 10);
    if (isNaN(stockNumber)) return;

    if (stockNumber === 0) {
    container.textContent = "Stock Prox.";
        return;
    }

    let rounded;
    let prefix;

    if (stockNumber < 1000) {
        rounded = stockNumber;
        prefix = "";
    } else {
        rounded = Math.floor(stockNumber / 100) * 100;
        prefix = "+";
    }

    const formatted = rounded.toLocaleString('es-ES');

    container.querySelectorAll("*").forEach(el => {
        if (el.children.length === 0 && el.textContent.match(/[\d,\.]+/)) {
            el.textContent = prefix + formatted;
        }
    });
}

// Ejecutar al cargar
document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".stock-info-js").forEach(formatStock);
});

// Observar solo el contenedor de productos
const productsContainer = document.querySelector(".products-container");
if (productsContainer) {
    const observer = new MutationObserver(mutations => {
        mutations.forEach(mutation => {
            mutation.addedNodes.forEach(node => {
                if (node.nodeType !== 1) return;

                if (node.classList?.contains("stock-info-js")) {
                    formatStock(node);
                } else {
                    node.querySelectorAll?.(".stock-info-js").forEach(formatStock);
                }
            });
        });
    });

    observer.observe(productsContainer, {
        childList: true,
        subtree: true
    });
}
</script>


<script>
function initColorOverlays(context = document) {
    context.querySelectorAll(".product-item").forEach(function (product) {
        const overlay = product.querySelector(".color-overlay");
        if (!overlay) return;

        const colors = overlay.querySelectorAll(".variant-preview");

        if (colors.length > 1) {
            product.classList.add("has-multiple-colors");
        }
    });
}

document.addEventListener("DOMContentLoaded", function () {

    // 👇 ESTA LÍNEA ES CLAVE
    initColorOverlays();

    // Owl carousel (lo que ya tenías)
    if (typeof $.fn.owlCarousel !== 'undefined') {
        $('.owl-carousel').on('changed.owl.carousel', function(event) {
            event.preventDefault();
            event.stopPropagation();
        });

        var owl = $('.owl-carousel').data('owl.carousel');
        if (owl && owl.settings) {
            owl.settings.autoHeight = false;
        }
    }
});

const observer = new MutationObserver(mutations => {
    mutations.forEach(mutation => {
        mutation.addedNodes.forEach(node => {
            if (node.nodeType !== 1) return;

            if (
                node.classList?.contains("product-item") ||
                node.querySelector?.(".product-item")
            ) {
                initColorOverlays(node);
            }
        });
    });
});

observer.observe(document.body, {
    childList: true,
    subtree: true
});

</script>